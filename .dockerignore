# Never bake secrets into an image layer.
.env

.git/
.github/

venv/
__pycache__/
*.py[cod]
*.egg-info/

.pytest_cache/
.ruff_cache/
tests/

logs/
*.log
tmp_uploads/

# Not needed at runtime — sample docs/eval data/scripts are for the offline
# eval harness (scripts/run_eval.py), not the live API or frontend.
docs/
data/
scripts/

# Node build artifacts. The api image never reads frontend-next/, and the
# frontend builds from its own context (./frontend-next) with its own
# .dockerignore — so these are pure upload cost here. A fresh clone doesn't have
# them, but a working checkout does: ~50k files tarred and shipped to the ACR
# build agent for nothing. `**/` because .dockerignore patterns are root-anchored.
**/node_modules/
**/.next/

.DS_Store
.vscode/
