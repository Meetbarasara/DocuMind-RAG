# DocuMind — Environment Variables Template
# Copy this file to .env and fill in your secrets.
# Never commit .env to version control.

# ── Groq (LLM) ────────────────────────────────────────────────────────────────
# Powers the chat LLM (llama-3.1-8b-instant). Generous free tier.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Embeddings run LOCALLY (sentence-transformers/all-mpnet-base-v2) — no key needed.
# First run downloads the model (~420MB) to your HF cache.

# ── Compliance judge model (optional — only for the KYC gap-analysis feature) ──
# The gap-analysis judge needs stronger reasoning than the 8b chat model. Free
# default = Cerebras gpt-oss-120b (their free models: gpt-oss-120b, zai-glm-4.7,
# gemma-4-31b — no Llama). Get a free key at https://cloud.cerebras.ai
# (create an API key). Swappable via JUDGE_PROVIDER (cerebras | groq | openrouter).
# CEREBRAS_API_KEY=csk-...
# JUDGE_PROVIDER=cerebras
# JUDGE_MODEL=gpt-oss-120b
# OPENROUTER_API_KEY=sk-or-...   # alternative provider (DeepSeek/Qwen free models)

# ── Cohere (reranking, L2) ────────────────────────────────────────────────────
# Optional: enables hosted reranking. Without it, reranking is skipped and
# results fall back to retrieval order. Get a key at https://dashboard.cohere.com
# COHERE_API_KEY=...

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=documind

# ── Observability: LangSmith (optional) ───────────────────────────────────────
# Set LANGSMITH_TRACING=true and add a key to trace every LLM call (latency,
# tokens, cost) to https://smith.langchain.com. Left OFF by default — no trace
# data leaves the process unless you opt in.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=documind

# ── Caching: Redis (optional) ─────────────────────────────────────────────────
# Set REDIS_URL to enable the exact-match query cache: repeated questions are
# served in <50ms, skipping retrieval + the LLM. Unset => cache disabled (no-op).
# Cache is auto-invalidated per user on every upload/delete so answers never go stale.
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=3600

# ── API server ────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# Defaults to http://localhost:8501 (the Streamlit dev server) if unset.
# CORS_ORIGINS=https://your-deployed-frontend.example.com
