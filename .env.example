# DocuMind — Environment Variables Template
# Copy this file to .env and fill in your secrets.
# Never commit .env to version control.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=documind

# ── Observability: LangSmith (optional) ───────────────────────────────────────
# Set LANGSMITH_TRACING=true and add a key to trace every LLM call (latency,
# tokens, cost) to https://smith.langchain.com. Left OFF by default — no trace
# data leaves the process unless you opt in.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=documind

# ── API server ────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# Defaults to http://localhost:8501 (the Streamlit dev server) if unset.
# CORS_ORIGINS=https://your-deployed-frontend.example.com
